# Supabase / PostgreSQL connection strings
# Get these from your Supabase project: Settings → Database → Connection string

# Pooled connection (used at runtime — Transaction mode via PgBouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# For future AI features (OpenAI, Gemini, etc.)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
